# ============================================================================
# VARIABLES DE ENTORNO - COCINA OCULTA POS (Backend)
# ============================================================================
# Copia este archivo como .env y completa los valores:
#   cp .env.example .env
#
# NUNCA subas el archivo .env al repositorio.
# ============================================================================

# ── Base de datos ────────────────────────────────────────────────────────────
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB
DATABASE_URL="postgresql://postgres:tu_password@localhost:5432/pos_restaurante"

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # development | production | test

# ── JWT ──────────────────────────────────────────────────────────────────────
# Genera claves seguras (mínimo 32 caracteres):
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=REEMPLAZAR_CON_CLAVE_GENERADA_DE_MINIMO_32_CARACTERES
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=REEMPLAZAR_CON_OTRA_CLAVE_DIFERENTE_DE_MINIMO_32_CARACTERES
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis se usa para caché de feature flags, UI config y queries frecuentes.
# Con Docker: docker run -d -p 6379:6379 redis:alpine
REDIS_URL=redis://localhost:6379

# ── CORS ─────────────────────────────────────────────────────────────────────
# URLs del frontend separadas por coma (sin espacios)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutos en ms
RATE_LIMIT_MAX_REQUESTS=2000  # máximo de peticiones por ventana

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug               # error | warn | info | debug

# ── Cron Jobs ─────────────────────────────────────────────────────────────────
# Schedule de alertas de inventario (formato cron, zona: America/Bogota)
# Ejemplos: "0 * * * *" = cada hora, "*/5 * * * *" = cada 5 min
ALERT_CRON_SCHEDULE="0 * * * *"

# ── Super Admin Único ─────────────────────────────────────────────────────────
# UUID fijo del único super administrador del sistema.
# CRÍTICO: Copiar el UUID exacto que queda en DB después del seed.
# NUNCA reutilizar un UUID, NUNCA cambiarlo en producción.
# Generar con: node -e "console.log(require('crypto').randomUUID())"
SUPER_ADMIN_UUID=REEMPLAZAR_CON_UUID_DEL_SUPER_ADMIN
