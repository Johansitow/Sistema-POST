# ============================================================================
# VARIABLES DE ENTORNO - COCINA OCULTA POS (Frontend)
# ============================================================================
# Copia este archivo como .env y ajusta las URLs a tu entorno:
#   cp .env.example .env
#
# Las variables VITE_* son expuestas al browser en tiempo de build.
# NUNCA coloques secretos (JWT secrets, passwords) en variables VITE_*.
# ============================================================================

# ── API Backend ───────────────────────────────────────────────────────────────
# URL base de la API REST (incluye /api/v1 al final)
VITE_API_URL=http://localhost:3000/api/v1

# ── WebSocket ─────────────────────────────────────────────────────────────────
# URL raíz del servidor (sin /api) — Socket.IO se conecta aquí
VITE_SOCKET_URL=http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_NAME=Cocina Oculta POS
VITE_APP_VERSION=1.0.0

# ── Debug / Desarrollo ────────────────────────────────────────────────────────
# Activa logs de axios, socket y stores en consola del browser
VITE_ENABLE_LOGS=true         # true | false
